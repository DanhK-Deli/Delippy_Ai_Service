# Chọn nhà cung cấp AI đang active. gemini/openai/claude có SDK riêng (bên
# dưới); bất kỳ tên nào khác (deepseek, groq, mistral, model tự train serve
# qua vLLM/Ollama/TGI, ...) đều dùng được ngay MIỄN LÀ API đó tương thích
# chuẩn OpenAI chat-completions - không cần sửa code, chỉ cần khai báo
# <TÊN_VIẾT_HOA>_API_KEY / <TÊN_VIẾT_HOA>_BASE_URL / <TÊN_VIẾT_HOA>_MODEL_CHEAP /
# <TÊN_VIẾT_HOA>_MODEL_COMPLEX (+ tuỳ chọn <TÊN_VIẾT_HOA>_EMBEDDING_MODEL) rồi
# đổi AI_PROVIDER sang đúng tên đó + restart service.
AI_PROVIDER=gemini

# OpenCode API
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL_CHEAP=gemini-3-flash
OPENCODE_MODEL_COMPLEX=gemini-3-flash
OPENCODE_DISABLE_REASONING=true

GEMINI_API_KEY=
GEMINI_API_VERSION=v1
GEMINI_ARTICLE_MODEL=gemini-2.5-flash
GEMINI_ANALYSIS_MODEL=gemini-2.5-pro
GEMINI_LIST_MODELS_ON_STARTUP=false

# OpenAI - điền OPENAI_API_KEY để dùng AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL_CHEAP=gpt-4o-mini
# OPENAI_MODEL_COMPLEX=gpt-4o

# DeepSeek - ví dụ cụ thể của cơ chế "provider bất kỳ" ở trên (không có class
# riêng trong code, factory tự build từ đúng 4 biến này khi AI_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL_CHEAP=deepseek-chat
# DEEPSEEK_MODEL_COMPLEX=deepseek-reasoner

# Ví dụ thêm 1 provider hoàn toàn mới (model tự train serve qua vLLM chẳng
# hạn) - chỉ cần bật AI_PROVIDER=myllm và điền đúng quy ước biến bên dưới:
# MYLLM_API_KEY=
# MYLLM_BASE_URL=http://localhost:8000/v1
# MYLLM_MODEL_CHEAP=my-finetuned-model
# MYLLM_MODEL_COMPLEX=my-finetuned-model

MONGO_URI=mongodb://localhost:27017/delippy_ai
DELIPPY_API_VERIFY_SSL=false
DELIPPY_API_BASE_URL=https://dev.delippy.com/api/v1

# development (mặc định) | staging | production. Người dùng DUY NHẤT hiện tại:
# app/knowledge/help/loader.py — validate Knowledge Base cho chatbot /help lúc
# khởi động. development/staging: có TODO/MISSING_FROM_DOCUMENT hoặc lỗi tham
# chiếu chỉ log cảnh báo, vẫn chạy. production: từ chối khởi động luôn nếu còn
# sót — BẮT BUỘC set "production" ở môi trường triển khai thật, nếu không set
# service sẽ mặc định chạy như development (bỏ qua fail-fast) dù đang phục vụ
# traffic thật.
APP_ENV=development

# legacy | vector (Atlas $vectorSearch, requires product_embeddings synced -
# see app/jobs/sync_products.py) | shadow (serves legacy, logs vector
# comparison) | hybrid (default - routes vector-first/legacy-first by
# intent, cross-falls-back on a zero-result miss). See app/retrieval/search_engine.py.
# Restored to "hybrid" (2026-07-10) after fixing the root cause of the
# earlier "máy giặt" bug: brand/spec text diluted embeddings, not task_type.
# See config.py's RETRIEVAL_MODE comment.
RETRIEVAL_MODE=hybrid
